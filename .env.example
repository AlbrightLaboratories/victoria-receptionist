# Victoria Albright — environment template.
# Copy to `.env` for local development. Do NOT commit `.env`.

# ----- Runtime mode -----
# local      — mock LLM, no Triton, no GitHub, no web search.
# staging    — real upstreams, but GitHub issue creation is logged-only.
# production — fully wired.
MODE=local

# ----- HTTP server -----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ----- Triton / LLM upstream -----
TRITON_URL=http://triton-inference.triton-inference.svc.cluster.local:8000
TRITON_OPENAI_COMPAT=true
LLM_MODEL=llama3.1:8b-instruct
LLM_TIMEOUT_S=60
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.4

# ----- Embedding endpoint (RAG index build) -----
EMBEDDING_URL=http://nemo-embedding.triton-inference.svc.cluster.local:8000
EMBEDDING_MODEL=intfloat/e5-large-v2
EMBEDDING_DIM=1024

# ----- Postgres / pgvector -----
DATABASE_URL=postgresql://victoria:victoria@postgres:5432/victoria
RAG_TOP_K=4
RAG_CONFIDENCE_THRESHOLD=0.72

# ----- Web search fallback -----
# Leave TAVILY_API_KEY unset to fall back to SearXNG.
TAVILY_API_KEY=
SEARXNG_URL=http://searxng.search.svc.cluster.local:8080

# ----- GitHub knowledge-gap issue creation -----
# In production we authenticate via `gh` CLI with a mounted token,
# but GH_TOKEN here works as a fallback for the REST path.
GH_REPO=AlbrightLaboratories/albrightlaboratories-dot-com
GH_TOKEN=
GH_GAP_LABEL=victoria-knowledge-gap

# ----- CORS / widget -----
ALLOWED_ORIGINS=https://albrightlab.com,https://www.albrightlab.com,http://localhost:8080
